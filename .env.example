# Environment Variables for Deexen Frontend
# Copy this file to .env and fill in your values. Never commit .env to git.

# API Configuration - point to your backend
VITE_API_URL=http://localhost:3000/api

# Set to 'false' to use real API backend (recommended)
# Set to 'true' only for local frontend-only development without a backend
VITE_USE_MOCK=false
